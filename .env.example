# Postgres connection string
DATABASE_URL=postgresql://user:pass@localhost:5432/missionready

# Redis connection string
REDIS_URL=redis://localhost:6379

# Better Auth
BETTER_AUTH_SECRET=replace-with-32-char-random-string-min
BETTER_AUTH_URL=http://localhost:3000

# Public app URL used by the browser-side auth client. Inlined at build time.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Social Providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Python AI Service
AI_SERVICE_URL=http://localhost:8000

# Email (Resend)
RESEND_API_KEY=

# Observability (added in later plans)
SENTRY_DSN=
POSTHOG_KEY=
